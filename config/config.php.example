<?php
// Start session
session_start();
if (isset($_SERVER['HTTP_X_FORWARDED_PROTO']) && $_SERVER['HTTP_X_FORWARDED_PROTO'] == 'https') {
    $_SERVER['HTTPS'] = 'on';
}
// Ganti blok IF ELSE BASE_URL lama dengan ini:
if (strpos($_SERVER['HTTP_HOST'], 'localhost') !== false || strpos($_SERVER['HTTP_HOST'], '127.0.0.1') !== false) {
    define('BASE_URL', '/my-wisata-pecut/');
} else {
    // Di internet, folder project kamu adalah subfolder dari domain utama
    define('BASE_URL', '/my-wisata-pecut/');
}
define('ASSETS_URL', BASE_URL . 'assets/');

// Site configuration
define('SITE_NAME', 'MyWisata');
define('SITE_EMAIL', 'info@mywisata.com');

// Upload configuration
define('UPLOAD_PATH', __DIR__ . '/../assets/images/');
define('MAX_FILE_SIZE', 5 * 1024 * 1024); // 5MB

// Pagination
define('ITEMS_PER_PAGE', 10);

// Xendit Configuration
define('XENDIT_SECRET_KEY', 'your_xendit_secret_key_here'); // Replace with your secret API key
define('XENDIT_PUBLIC_KEY', 'your_xendit_public_key_here'); // Replace with your public API key
define('XENDIT_WEBHOOK_TOKEN', 'your_webhook_token_here'); // Get from Xendit dashboard

// Include database
require_once __DIR__ . '/database.php';

// Helper functions
function base_url($path = '')
{
    return BASE_URL . ltrim($path, '/');
}

function assets_url($path = '')
{
    return ASSETS_URL . ltrim($path, '/');
}

function redirect($url)
{
    header("Location: " . base_url($url));
    exit();
}

function get_full_base_url()
{
    $protocol = isset($_SERVER['HTTPS']) && $_SERVER['HTTPS'] === 'on' ? 'https' : 'http';
    $host = $_SERVER['HTTP_HOST'];
    return $protocol . '://' . $host . BASE_URL;
}

function is_logged_in()
{
    return isset($_SESSION['user_id']);
}

function is_admin()
{
    return isset($_SESSION['user_role']) && $_SESSION['user_role'] === 'admin';
}

function get_user_id()
{
    return $_SESSION['user_id'] ?? null;
}

function get_user_name()
{
    return $_SESSION['user_name'] ?? '';
}

function get_user_email()
{
    return $_SESSION['user_email'] ?? '';
}

function get_user_role()
{
    return $_SESSION['user_role'] ?? '';
}

// Generate unique ticket code
function generate_ticket_code($length = 10)
{
    $characters = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    $charactersLength = strlen($characters);
    $randomString = '';
    for ($i = 0; $i < $length; $i++) {
        $randomString .= $characters[rand(0, $charactersLength - 1)];
    }
    return 'TKT' . date('Ymd') . $randomString;
}

// Format currency
function format_currency($amount)
{
    return 'Rp ' . number_format($amount, 0, ',', '.');
}

// Format date
function format_date($date, $format = 'd M Y')
{
    return date($format, strtotime($date));
}

// Sanitize input
function sanitize($input)
{
    return htmlspecialchars(trim($input), ENT_QUOTES, 'UTF-8');
}

// Validate email
function is_valid_email($email)
{
    return filter_var($email, FILTER_VALIDATE_EMAIL);
}

// Flash message
function set_flash_message($type, $message)
{
    $_SESSION['flash'][$type] = $message;
}

function get_flash_message($type)
{
    if (isset($_SESSION['flash'][$type])) {
        $message = $_SESSION['flash'][$type];
        unset($_SESSION['flash'][$type]);
        return $message;
    }
    return '';
}

// Check if flash message exists
function has_flash_message($type)
{
    return isset($_SESSION['flash'][$type]);
}
